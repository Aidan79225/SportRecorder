<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:background="@color/bg_black"
        android:visibility="gone"
        android:padding="20dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:srcCompat="@drawable/ic_baseline_no_food_24"
            android:layout_column="0"
            android:layout_row="0"
            android:layout_margin="10dp"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/diet_status_fasting"
            android:textSize="18sp"
            android:layout_gravity="center_vertical"
            android:layout_column="1"
            android:layout_row="0"
            />

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:srcCompat="@drawable/ic_baseline_fastfood_24"
            android:layout_column="0"
            android:layout_row="1"
            android:layout_margin="10dp"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/diet_status_eating"
            android:layout_gravity="center_vertical"
            android:textSize="18sp"
            android:layout_column="1"
            android:layout_row="1"
            />

        <TextView
            android:id="@+id/fasting_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="65dp"
            android:text="16"
            android:layout_gravity="end|center_vertical"
            android:gravity="end|center_vertical"
            android:textSize="18sp"
            android:layout_column="2"
            android:layout_row="0"
            />

        <ImageView
            android:id="@+id/fasting_image_view"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:srcCompat="@drawable/ic_baseline_arrow_drop_down"
            android:layout_column="3"
            android:layout_row="0"
            android:layout_margin="10dp"
            />


        <TextView
            android:id="@+id/eating_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="65dp"
            android:gravity="end|center_vertical"
            android:text="8"
            android:layout_gravity="end|center_vertical"
            android:textSize="18sp"
            android:layout_column="2"
            android:layout_row="1"
            />

        <ImageView
            android:id="@+id/eating_image_view"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:srcCompat="@drawable/ic_baseline_arrow_drop_down"
            android:layout_column="3"
            android:layout_row="1"
            android:layout_margin="10dp"
            />
        <Space
            android:layout_row="2"
            android:layout_column="0"
            android:layout_columnSpan="4"
            android:layout_height="30dp"
            android:layout_width="match_parent"
            />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:layout_row="3"
            android:layout_column="0"
            android:layout_columnSpan="4"
            >

            <TextView
                android:id="@+id/cancel_text_view"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_stoke_round_light_green"
                android:layout_marginTop="20dp"
                android:layout_gravity="fill_horizontal"
                android:text="CANCEL"
                android:gravity="center"
                android:layout_margin="10dp"
                android:clickable="true"
                android:focusable="true"
                />
            <TextView
                android:id="@+id/create_text_view"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_round_light_green"
                android:layout_marginTop="20dp"
                android:layout_gravity="fill_horizontal"
                android:text="CREATE"
                android:textColor="@color/black"
                android:gravity="center"
                android:paddingStart="40dp"
                android:paddingEnd="40dp"
                android:layout_margin="10dp"
                android:clickable="true"
                android:focusable="true"
                />
        </LinearLayout>

    </GridLayout>
    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>